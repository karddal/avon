        },
        {
          "name": "CORS_ORIGIN",
          "value": "[\"https://avon.ac\", \"http://avon.ac\", \"https://www.avon.ac\", \"http://www.avon.ac\"]"
        }
      ],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:418272753045:secret:backend_db-dsPz0p"
        },
        {
          "name": "GITLAB_API_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:418272753045:secret:GITLAB_API_TOKEN-0XK28o"
        },
        {
          "name": "GITLAB_BASE_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:418272753045:secret:GITLAB_BASE_URL-tXc9NY"
        },
        {
          "name": "GITLAB_ROOT_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:418272753045:secret:GITLAB_ROOT_ID-IZxtdP"
        }
      ],
      "ulimits": [],
