{
    "taskDefinitionArn": "",
    "containerDefinitions": [
        {
            "name": "frontend",
            "image": "",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "frontend-3000-tcp",
                    "containerPort": 3000,
                    "hostPort": 3000,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "BETTER_AUTH_URL",
                    "value": "https://avon.ac"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "BA_DATABASE_URL",
                    "valueFrom": "arn:aws:secretsmanager:eu-north-1:418272753045:secret:db_url-WxgpLT"
                },
                {
                    "name": "BETTER_AUTH_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:eu-north-1:418272753045:secret:BA_SECRET-qpcrgL"
                }
            ],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/AvonFrontend",
                    "awslogs-create-group": "true",
                    "awslogs-region": "eu-north-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "AvonFrontend",
    "executionRoleArn": "arn:aws:iam::418272753045:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "tags": []
}
