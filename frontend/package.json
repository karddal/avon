  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack && npm run copy-static",
    "copy-static": "shx cp -r .next/static .next/standalone/.next/ && shx cp -r public .next/standalone/",
    "start": "node .next/standalone/server.js",
    "lint": "biome check",
    "format": "biome format --write",
    "start:backend": "cd ../backend && cross-env ENV=dev IGNORE_AUTH=False TESTING_MODE=True TEST_FIXTURE_KEY=test GITLAB_API_TOKEN=$GITLAB_API_TOKEN GITLAB_BASE_URL=https://gitlab.com/api/v4 GITLAB_ROOT_ID=124674879 DATABASE_URL=sqlite:///../sqlite.db CORS_ORIGIN=\"[\\\"http://localhost:3000\\\"]\" JWKS_URL=http://localhost:3000/api/auth/jwks JWT_AUDIENCE=https://localhost:3000 JWT_ISSUER=https://localhost:3000 uv run fastapi dev",
    "cy:run": "cypress run",
    "test": "npm run db:seed && cross-env CI_MODE=True TESTING_MODE=True NEXT_PUBLIC_API_URL=http://localhost:8000 NEXT_PUBLIC_CDN_PATH= npm run build && npm run test:run",
    "test:run": "cross-env CI_MODE=True TESTING_MODE=True ENV=development BETTER_AUTH_SECRET=wwZgZ19qBU3L0Rxf4oVzAbpw7xkmDOLG BETTER_AUTH_URL=https://localhost:3000 start-server-and-test start:backend http-get://localhost:8000/check/health start http://localhost:3000 cy:run",
    "db:seed": "cd ../backend && cross-env DATABASE_URL=sqlite:///../sqlite.db uv run python -m app.cli.manage seeding"
  },
